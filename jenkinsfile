pipeline {
    agent any

    stages {

        stage('Get Code') {
            steps {
                sh '''
                    echo "Verificando entorno"
                    git --version
                    ls -la
                '''
            }
        }

        stage('Static Test') {
            steps {
                sh '''
                    echo "Creando entorno virtual"
                    python3 -m venv venv
        
                    echo "Activando entorno virtual"
                    . venv/bin/activate
        
                    echo "Instalando dependencias"
                    pip install flake8 bandit flake8-html
        
                    echo "Ejecutando flake8"
                    flake8 src --format=html --htmldir=flake8-report || true
        
                    echo "Ejecutando bandit"
                    bandit -r src -f html -o bandit-report.html || true
                '''
            }

            post {
                always {
                    echo "Publicando reportes"
                    publishHTML(target: [
                        reportDir: 'flake8-report',
                        reportFiles: 'index.html',
                        reportName: 'Flake8 Report'
                    ])

                    publishHTML(target: [
                        reportDir: '.',
                        reportFiles: 'bandit-report.html',
                        reportName: 'Bandit Report'
                    ])
                }
            }
        }
        stage('Unit Tests') {
            steps {
                sh '''
                    echo "Activando entorno virtual"
                    . venv/bin/activate
        
                    echo "Instalando pytest"
                    pip install pytest
        
                    echo "Ejecutando pytest"
                    pytest test/unit/TestToDo.py test/integration/todoApiTest.py -q --disable-warnings --maxfail=1
                '''
            }
        }
        stage('Build SAM') {
            when {
                branch 'master'
            }
            steps {
                sh '''
                    echo "Construyendo aplicación con SAM"
                    sam build
                '''
            }
        }
        
        stage('Deploy SAM') {
            when {
                branch 'master'
            }
            steps {
                sh '''
                    echo "Desplegando aplicación con SAM"
                    sam deploy --no-confirm-changeset --no-fail-on-empty-changeset
                '''
            }
        }
        
        stage('API Tests') {
            when {
                branch 'master'
            }
            steps {
                sh '''
                    echo "Ejecutando pruebas curl"
                    API_URL=$(aws cloudformation describe-stacks --stack-name todo-list-aws --query "Stacks[0].Outputs[?OutputKey=='ApiUrl'].OutputValue" --output text)
        
                    echo "Probando endpoint GET /todos"
                    curl -s $API_URL/todos
        
                    echo "Probando endpoint POST /todos"
                    curl -s -X POST $API_URL/todos -d '{"task":"test"}' -H "Content-Type: application/json"
                '''
            }
        }
    }
}