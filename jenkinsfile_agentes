pipeline {
    agent none

    stages {

        stage('Get Code') {
            agent any
            steps {
                sh '''
                    echo "=== GET CODE ==="
                    whoami
                    hostname
                '''

                // DESCARGAR SAMCONFIG SEGÚN LA RAMA
                script {
                    if (env.BRANCH_NAME == "develop") {
                        echo "Rama detectada: develop → usando configuración STAGING"
                        sh '''
                            curl -o samconfig.toml \
                            https://raw.githubusercontent.com/JulioCesar9514/todo-list-aws-config/staging/samconfig.toml
                        '''
                    } else if (env.BRANCH_NAME == "master") {
                        echo "Rama detectada: master → usando configuración PRODUCTION"
                        sh '''
                            curl -o samconfig.toml \
                            https://raw.githubusercontent.com/JulioCesar9514/todo-list-aws-config/production/samconfig.toml
                        '''
                    } else {
                        error "Rama no soportada para este pipeline (solo develop y master)"
                    }
                }
            }
        }

        stage('Static Test') {
            agent { label 'static-node' }
            steps {
                sh '''
                    echo "=== STATIC TEST ==="
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install flake8 bandit flake8-html
                    flake8 src --format=html --htmldir=flake8-report
                    bandit -r src -f html -o bandit-report.html
                '''
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: 'flake8-report',
                        reportFiles: 'index.html',
                        reportName: 'Flake8 Report'
                    ])
                    publishHTML(target: [
                        reportDir: '.',
                        reportFiles: 'bandit-report.html',
                        reportName: 'Bandit Report'
                    ])
                }
            }
        }

        stage('Unit Tests') {
            agent any
            steps {
                sh '''
                    echo "=== UNIT TESTS ==="
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install pytest boto3 moto
                    pytest test/unit/TestToDo.py -q --disable-warnings --maxfail=1 || true
                '''
            }
        }

        stage('Build SAM') {
            agent { label 'api-node' }
            steps {
                sh '''
                    echo "=== BUILD SAM ==="
                    sam build
                '''
            }
        }

        stage('Deploy SAM') {
            agent { label 'api-node' }
            steps {
                sh '''
                    echo "=== DEPLOY SAM ==="

                    # BORRAR CUALQUIER SAMCONFIG ANTIGUO DEL WORKSPACE
                    rm -f .aws-sam/samconfig.toml || true

                    # USAR EL QUE DESCARGAMOS EN GET CODE
                    sam deploy --no-fail-on-empty-changeset
                '''
            }
        }

        stage('Get BaseURL') {
            agent { label 'api-node' }
            steps {
                script {
                    def stackName = (env.BRANCH_NAME == "master") 
                        ? "production-todo-list-aws"
                        : "staging-todo-list-aws"

                    sh """
                        echo "=== GET BASEURL ==="
                        BASEURL=\$(aws cloudformation describe-stacks \
                            --stack-name ${stackName} \
                            --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                            --output text)
                        echo "\$BASEURL" > baseurl.txt
                    """
                }
                stash includes: 'baseurl.txt', name: 'baseurl'
            }
        }

        stage('REST Tests') {
            agent { label 'api-node' }
            steps {
                unstash 'baseurl'
                sh '''
                    echo "=== REST TESTS ==="
                    BASEURL=$(cat baseurl.txt)
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install pytest requests
                    export BASEURL=$BASEURL
                    pytest test/rest/toDoApiTest.py -q --disable-warnings --maxfail=1
                '''
            }
        }
    }
}
