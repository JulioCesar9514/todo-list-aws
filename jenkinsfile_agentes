pipeline {
    agent none

    stages {

        stage('Get Code') {
            agent any
            steps {
                sh '''
                    echo "Get Code OK"
                    whoami
                    hostname
                '''
            }
        }

        stage('Static Test') {
            agent { label 'static-node' }
            steps {
                sh '''
                    echo "=== STATIC TEST ==="
                    whoami
                    hostname

                    python3 -m venv venv
                    . venv/bin/activate

                    pip install flake8 bandit flake8-html

                    flake8 src --format=html --htmldir=flake8-report
                    bandit -r src -f html -o bandit-report.html
                '''
            }

            post {
                always {
                    publishHTML(target: [
                        reportDir: 'flake8-report',
                        reportFiles: 'index.html',
                        reportName: 'Flake8 Report'
                    ])

                    publishHTML(target: [
                        reportDir: '.',
                        reportFiles: 'bandit-report.html',
                        reportName: 'Bandit Report'
                    ])
                }
            }
        }

        stage('Unit Tests') {
            agent any
            steps {
                sh '''
                    echo "=== UNIT TESTS ==="
                    whoami
                    hostname

                    python3 -m venv venv
                    . venv/bin/activate

                    pip install pytest boto3

                    pytest test/unit/TestToDo.py -q --disable-warnings --maxfail=1 || true
                '''
            }
        }

        stage('Build SAM') {
            agent { label 'api-node' }
            steps {
                sh '''
                    echo "=== BUILD SAM ==="
                    whoami
                    hostname

                    sam build
                '''
            }
        }

        stage('Deploy SAM') {
            agent { label 'api-node' }
            steps {
                sh '''
                    echo "=== DEPLOY SAM ==="
                    whoami
                    hostname

                    sam deploy
                '''
            }
        }

        stage('Get BaseURL') {
            agent { label 'api-node' }
            steps {
                sh '''
                    echo "=== GET BASEURL ==="

                    BASEURL=$(aws cloudformation describe-stacks \
                        --stack-name staging-todo-list-aws \
                        --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                        --output text)

                    echo "$BASEURL" > baseurl.txt
                '''

                stash includes: 'baseurl.txt', name: 'baseurl'
            }
        }

        stage('REST Tests') {
            agent { label 'api-node' }
            steps {
                unstash 'baseurl'

                sh '''
                    echo "=== REST TESTS ==="
                    whoami
                    hostname

                    BASEURL=$(cat baseurl.txt)
                    echo "BaseURL: $BASEURL"

                    python3 -m venv venv
                    . venv/bin/activate

                    pip install pytest requests

                    export BASEURL=$BASEURL

                    pytest test/rest/toDoApiTest.py -q --disable-warnings --maxfail=1
                '''
            }
        }

    }
}
