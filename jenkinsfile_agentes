pipeline {
    agent none

    stages {

        stage('Get Code') {
            agent any
            steps {
                sh '''
                    echo "Get Code OK"
                    whoami
                    hostname
                '''
            }
        }

        stage('Static Test') {
            agent { label 'static-node' }
            steps {
                sh '''
                    echo "=== STATIC TEST ==="
                    whoami
                    hostname

                    python3 -m venv venv
                    . venv/bin/activate

                    pip install flake8 bandit flake8-html

                    flake8 src --format=html --htmldir=flake8-report || true
                    bandit -r src -f html -o bandit-report.html || true
                '''
            }

            post {
                always {
                    publishHTML(target: [
                        reportDir: 'flake8-report',
                        reportFiles: 'index.html',
                        reportName: 'Flake8 Report'
                    ])

                    publishHTML(target: [
                        reportDir: '.',
                        reportFiles: 'bandit-report.html',
                        reportName: 'Bandit Report'
                    ])
                }
            }
        }

        stage('Unit Tests') {
            agent any
            steps {
                sh '''
                    echo "=== UNIT TESTS ==="
                    whoami
                    hostname

                    python3 -m venv venv
                    . venv/bin/activate

                    pip install pytest

                    pytest test/unit/TestToDo.py -q --disable-warnings --maxfail=1 || true
                '''
            }
        }

        stage('Build SAM') {
            when {
                branch 'develop'
            }
            agent { label 'api-node' }
            steps {
                sh '''
                    echo "=== BUILD SAM ==="
                    whoami
                    hostname

                    sam build
                '''
            }
        }

        stage('Deploy SAM') {
            when {
                branch 'develop'
            }
            agent { label 'api-node' }
            steps {
                sh '''
                    echo "=== DEPLOY SAM ==="
                    whoami
                    hostname

                    sam deploy
                '''
            }
        }
    }
}
